,{"filePath":"35","messages":"36","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"37"},"/Users/mandatran/Desktop/mandatran.github.io/src/App.js",["38","39","40","41","42"],"/Users/mandatran/Desktop/mandatran.github.io/src/index.js",[],["43","44"],"/Users/mandatran/Desktop/mandatran.github.io/src/theme.js",[],"/Users/mandatran/Desktop/mandatran.github.io/src/components/Socials.js",[],"/Users/mandatran/Desktop/mandatran.github.io/src/components/NavBar.js",["45"],"import React from 'react';\nimport { makeStyles } from '@material-ui/core/styles';\nimport Link from '@material-ui/core/Link';\nimport Typography from '@material-ui/core/Typography';\nimport Box from '@material-ui/core/Box';\n\nconst useStyles = makeStyles((theme) => ({\n  root: {\n    '& > *': {\n      color: 'black',\n      fontSize: '1rem',\n    },\n  },\n}));\n\nexport default function NavBar() {\n  const classes = useStyles();\n  return (\n      <Box width={1} py={3} className={classes.root} textAlign=\"right\" >\n        <Link to='/About' className='nav-link'>About</Link>\n      </Box>\n  );\n}\n","/Users/mandatran/Desktop/mandatran.github.io/src/components/Research.js",[],"/Users/mandatran/Desktop/mandatran.github.io/src/components/Projects.js",["46"],"import React from 'react';\nimport { makeStyles } from '@material-ui/core/styles';\nimport Box from '@material-ui/core/Box';\nimport Link from '@material-ui/core/Link';\nimport Typography from '@material-ui/core/Typography';\n\nconst useStyles = makeStyles((theme) => ({\n  root: {\n    fontSize: '3rem',\n  },\n}));\n\nexport default function Projects() {\n  const classes = useStyles();\n  return (\n      <Box pb={8} >\n        <Typography variant=\"h4\" component=\"h1\" className={classes.root} gutterBottom>\n            Projects\n        </Typography>\n      </Box>\n  );\n}\n","/Users/mandatran/Desktop/mandatran.github.io/src/components/About.js",["47"],"import React from 'react';\nimport { makeStyles } from '@material-ui/core/styles';\nimport Box from '@material-ui/core/Box';\nimport Grid from '@material-ui/core/Grid';\nimport Link from '@material-ui/core/Link';\nimport Typography from '@material-ui/core/Typography';\nimport profilePic from '../img/profilepic.gif';\n\nconst useStyles = makeStyles((theme) => ({\n  root: {\n    fontSize: '3rem',\n  },\n  img: {\n      maxWidth: '100%',\n  },\n  aboutTxt: {\n      fontSize: '2rem',\n  },\n}));\n\nexport default function About() {\n  const classes = useStyles();\n  return (\n    <Box pb={8} >\n        <Box pb={2}>\n            <Typography variant=\"h4\" component=\"h1\" className={classes.root} gutterBottom>\n                About\n            </Typography>\n        </Box>\n\n        <Grid container spacing={3}>\n            <Grid item xs={12} sm={4}>\n                <img src={profilePic} alt=\"profile pic\" className={classes.img} />\n            </Grid>\n            <Grid item xs={12} sm={8} className={classes.aboutTxt} >\n                <Typography gutterBottom>\n                    Hi, I’m Manda, a fourth-year undergraduate student at UCSD studying Mathematics and Computer Science.\n                </Typography>\n                <Typography variant=\"h5\" component=\"h5\" >\n                    Currently \n                </Typography>\n                <Typography gutterBottom>\n                    An Undergraduate Researcher at CAIDA, Web Developer at CSSA at UCSD, applying to Master’s Programs in Computer Science with a focus in Security/Cryptography.\n                </Typography>\n                <Typography variant=\"h5\" component=\"h5\" >\n                    Previously \n                </Typography>\n                <Typography gutterBottom>\n                    2x Intern at Hive Media Group, SWE Intern at ThoughtSTEM.\n                </Typography>\n                <Typography variant=\"h5\" component=\"h5\" >\n                    Up Next\n                </Typography>\n                <Typography gutterBottom>\n                    EDG Intern at MathWorks.\n                </Typography>\n            </Grid>\n        </Grid>\n    </Box>\n  );\n}\n",{"ruleId":"48","severity":1,"message":"49","line":7,"column":8,"nodeType":"50","messageId":"51","endLine":7,"endColumn":12},{"ruleId":"48","severity":1,"message":"52","line":9,"column":8,"nodeType":"50","messageId":"51","endLine":9,"endColumn":14},{"ruleId":"48","severity":1,"message":"53","line":10,"column":8,"nodeType":"50","messageId":"51","endLine":10,"endColumn":16},{"ruleId":"48","severity":1,"message":"54","line":11,"column":8,"nodeType":"50","messageId":"51","endLine":11,"endColumn":16},{"ruleId":"48","severity":1,"message":"55","line":12,"column":8,"nodeType":"50","messageId":"51","endLine":12,"endColumn":13},{"ruleId":"56","replacedBy":"57"},{"ruleId":"58","replacedBy":"59"},{"ruleId":"48","severity":1,"message":"60","line":4,"column":8,"nodeType":"50","messageId":"51","endLine":4,"endColumn":18},{"ruleId":"48","severity":1,"message":"49","line":4,"column":8,"nodeType":"50","messageId":"51","endLine":4,"endColumn":12},{"ruleId":"48","severity":1,"message":"49","line":5,"column":8,"nodeType":"50","messageId":"51","endLine":5,"endColumn":12},"no-unused-vars","'Link' is defined but never used.","Identifier","unusedVar","'NavBar' is defined but never used.","'Research' is defined but never used.","'Projects' is defined but never used.","'About' is defined but never used.","no-native-reassign",["61"],"no-negated-in-lhs",["62"],"'Typography' is defined but never used.","no-global-assign","no-unsafe-negation"]